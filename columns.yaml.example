# Example columns configuration for --use-columns
# Copy to columns.yaml and edit the list. Column names must match after cleaning.
# Only these columns will be read and exported when you run:
#   python src/merge_excel_files.py ./Data --use-columns
#   python src/merge_excel_files.py ./Data --use-columns --columns-file my_columns.yaml

columns:
  - Date
  - Brand
  - Campaign name
  - Impressions
  - Clicks
